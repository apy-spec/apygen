digraph "list_operations" {
    "Constraint()" [label="#return(None)"];
    "Constraint(location=1:0)" [label="None ⊑ ls@{list_operations[1:0]} ∧ #defined(ls@{list_operations[1:0]})"];
    "Constraint(location=3:0)" [label="(ls@{list_operations[3:8]})[0] ⊑ first@{list_operations[3:0]} ∧ #defined(first@{list_operations[3:0]})"];
    "Constraint(location=3:8)" [label="ls@{list_operations[1:0]} ⊑ ls@{list_operations[3:8]}"];
    "Constraint(location=4:0)" [label="(ls@{list_operations[4:9]})[1] ⊑ second@{list_operations[4:0]} ∧ #defined(second@{list_operations[4:0]})"];
    "Constraint(location=4:9)" [label="ls@{list_operations[1:0]} ⊑ ls@{list_operations[4:9]}"];
    "Entry" -> "Constraint(location=1:0)";
    "Constraint()" -> "TypeExit";
    "Constraint(location=1:0)" -> "Constraint(location=3:8)" [label="#succeed(ls@{list_operations[1:0]})"];
    "Constraint(location=1:0)" -> "ExceptionExit" [label="#raise(ls@{list_operations[1:0]})"];
    "Constraint(location=3:0)" -> "Constraint(location=4:9)" [label="#succeed(ls@{list_operations[1:0]})"];
    "Constraint(location=3:0)" -> "ExceptionExit" [label="#raise(ls@{list_operations[1:0]})"];
    "Constraint(location=3:8)" -> "Constraint(location=3:0)" [label="#succeed((ls@{list_operations[3:8]})[0])"];
